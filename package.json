{
  "name": "jungle-safari-inventory",
  "version": "1.0.0",
  "description": "Jungle Safari Store Inventory Management System",
  "main": "index.js",
  "scripts": {
    "start": "cd frontend && npm start",
    "start:backend": "cd backend && npm start",
    "dev": "concurrently \"npm run start\" \"npm run start:backend\"",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "build": "cd frontend && npm run build",
    "build:backend": "cd backend && npm install",
    "deploy:frontend": "cd frontend && vercel --prod",
    "deploy:backend": "cd backend && vercel --prod",
    "deploy:all": "npm run deploy:backend && npm run deploy:frontend"
  },
  "keywords": [
    "inventory",
    "safari",
    "management",
    "react",
    "nodejs",
    "mongodb"
  ],
  "author": "Abhishek Gupta",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
